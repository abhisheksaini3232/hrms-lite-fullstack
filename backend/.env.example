# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=hrms_lite

# Comma-separated list (include Vercel URL after deploy)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production example:
# CORS_ORIGINS=https://hrms-lite-fullstack-1gk4-oqawjuct6.vercel.app

# JWT / auth settings (override for production)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=60
